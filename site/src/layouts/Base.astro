---
interface Props {
  title: string;
  lang?: string;
}

const { title, lang = 'en' } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link rel="icon" href={`${import.meta.env.BASE_URL}icon.svg`} type="image/svg+xml">
  <style is:global>
    :root {
      --color-cyber-bg: #050a12;
      --color-cyber-black: #020617;
      --color-cyber-cyan: #22d3ee;
      --color-cyber-cyan-glow: rgba(34, 211, 238, 0.4);
      --color-cyber-magenta: #ec4899;
      --color-cyber-magenta-glow: rgba(236, 72, 153, 0.4);
      --color-cyber-blue: #3b82f6;
      --color-cyber-dark-glass: rgba(15, 23, 42, 0.7);
      --color-cyber-border: rgba(34, 211, 238, 0.2);
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background-color: var(--color-cyber-bg);
      color: #cbd5e1;
      background-image: 
        linear-gradient(to right, rgba(34, 211, 238, 0.05) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(34, 211, 238, 0.05) 1px, transparent 1px);
      background-size: 30px 30px;
    }

    .glass-panel {
      background-color: var(--color-cyber-dark-glass);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--color-cyber-border);
      border-radius: 0.75rem;
      box-shadow: 0 0 15px var(--color-cyber-cyan-glow);
    }
    
    .text-glow {
      text-shadow: 0 0 10px var(--color-cyber-cyan-glow);
    }
    
    .text-magenta-glow {
      text-shadow: 0 0 10px var(--color-cyber-magenta-glow);
    }
    
    .btn-cyber {
      position: relative;
      overflow: hidden;
      background-color: transparent;
      color: var(--color-cyber-cyan);
      font-family: 'Roboto Mono', 'Fira Code', monospace;
      font-weight: 700;
      letter-spacing: 0.1em;
      padding: 0.75rem 2rem;
      outline: none;
      border: 1px solid var(--color-cyber-cyan);
      text-transform: uppercase;
      transition: all 0.3s ease-in-out;
      cursor: pointer;
      box-shadow: 0 0 10px var(--color-cyber-cyan-glow), inset 0 0 10px var(--color-cyber-cyan-glow);
    }
    
    .btn-cyber:hover {
      background-color: var(--color-cyber-cyan);
      color: var(--color-cyber-black);
      box-shadow: 0 0 20px var(--color-cyber-cyan), inset 0 0 20px var(--color-cyber-cyan);
    }
    
    .btn-cyber::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(to right, transparent, rgba(255,255,255,0.2), transparent);
      transform: skewX(-45deg);
      transition: all 0.5s ease-in-out;
    }
    
    .btn-cyber:hover::before {
      left: 100%;
    }

    .glitch-wrapper {
      position: relative;
    }

    .glitch {
      position: relative;
      color: white;
      font-weight: 800;
      display: inline;
      animation: glitch-effect 4s infinite;
    }

    @keyframes glitch-effect {
      0%, 93%, 100% { 
        text-shadow: 0 0 10px var(--color-cyber-cyan-glow); 
      }
      94% { 
        text-shadow: 4px 0 var(--color-cyber-magenta), -4px 0 var(--color-cyber-cyan); 
        color: white;
      }
      96% { 
        text-shadow: -4px 0 var(--color-cyber-magenta), 4px 0 var(--color-cyber-cyan); 
        color: #ffd1eb;
      }
      98% { 
        text-shadow: 2px -2px var(--color-cyber-magenta), -2px 2px var(--color-cyber-cyan); 
        color: white;
      }
    }
  </style>
</head>
<body class="bg-dark-950 text-gray-200 antialiased">
  <slot />

  <!-- Image Modal Overlay -->
  <div id="image-modal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-[#020617]/95 backdrop-blur-md opacity-0 transition-opacity duration-300">
    <button id="modal-close" class="absolute top-6 right-6 text-slate-400 hover:text-brand-500 transition-colors z-[101]">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
    <div class="relative w-[90vw] h-[90vh] flex items-center justify-center p-4">
      <img id="modal-image" src="" alt="Enlarged View" class="max-w-full max-h-full object-contain rounded-lg shadow-[0_0_50px_rgba(34,211,238,0.15)] ring-1 ring-white/10 scale-95 transition-transform duration-300" />
    </div>
  </div>

  <script>
    const images = document.querySelectorAll('.arch-zoomable');
    const modal = document.getElementById('image-modal');
    const modalImg = document.getElementById('modal-image') as HTMLImageElement;
    const closeBtn = document.getElementById('modal-close');

    function openModal(src: string) {
      if (!modal || !modalImg) return;
      modalImg.src = src;
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      // Trigger reflow
      void modal.offsetWidth;
      modal.classList.remove('opacity-0');
      modalImg.classList.remove('scale-95');
      modalImg.classList.add('scale-100');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      if (!modal || !modalImg) return;
      modal.classList.add('opacity-0');
      modalImg.classList.remove('scale-100');
      modalImg.classList.add('scale-95');
      
      setTimeout(() => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        modalImg.src = '';
        document.body.style.overflow = '';
      }, 300); // match transition duration
    }

    images.forEach(img => {
      img.addEventListener('click', (e) => {
        const src = (e.currentTarget as HTMLImageElement).src;
        openModal(src);
      });
    });

    closeBtn?.addEventListener('click', closeModal);
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
    
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
        closeModal();
      }
    });
  </script>
</body>
</html>
