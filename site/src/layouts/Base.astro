---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link rel="icon" href={`${import.meta.env.BASE_URL}icon.svg`} type="image/svg+xml">
  <style is:global>
    html { scroll-behavior: smooth; }
    body { font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  </style>
</head>
<body class="bg-dark-950 text-gray-200 antialiased">
  <slot />
</body>
</html>
