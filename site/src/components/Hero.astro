---
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative pt-32 pb-20 px-6">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,var(--color-cyber-cyan-glow)_0%,transparent_60%)] pointer-events-none"></div>

  <div class="max-w-4xl mx-auto text-center relative z-10 flex flex-col items-center">
    <div class="inline-flex items-center gap-2 px-3 py-1 bg-cyber-magenta/10 border border-[#ec4899]/30 rounded-full text-[#ec4899] font-mono text-xs uppercase tracking-widest mb-8 shadow-[0_0_15px_rgba(236,72,153,0.3)]">
      <span class="w-2 h-2 rounded-full bg-[#ec4899] animate-pulse"></span>
      System Online
    </div>

    <h1 class="text-5xl md:text-7xl font-bold font-mono tracking-tighter mb-6 leading-tight">
      <span class="glitch-wrapper block mb-2">
        <span class="glitch uppercase" data-text={t('hero.title')}>{t('hero.title')}</span>
      </span>
    </h1>
    
    <p class="text-lg md:text-xl text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed font-sans" set:html={t('hero.subtitle').replace('\\n', '<br class="hidden sm:block">')}>
    </p>

    <div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
      <a href="#architecture" class="btn-cyber block text-center">
        {t('hero.cta')}
      </a>
      <a href="https://github.com/stormixus/OpsView" target="_blank" class="flex items-center gap-2 font-mono text-slate-300 hover:text-[#22d3ee] transition-colors uppercase tracking-widest border-b border-transparent hover:border-[#22d3ee] pb-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        {t('nav.github')}
      </a>
    </div>
  </div>
</section>
