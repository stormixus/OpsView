---

<section id="architecture" class="py-20 px-6 bg-dark-900">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-3xl font-bold text-white text-center mb-4">아키텍처</h2>
    <p class="text-gray-400 text-center mb-12 max-w-xl mx-auto">Agent — Relay — Viewer 3-tier 구조</p>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <div class="rounded-xl border border-white/5 overflow-hidden bg-dark-800 p-2">
        <h3 class="w-full text-left font-mono text-xs uppercase text-slate-400 tracking-widest mb-2 border-b border-white/10 pb-2 px-2 pt-2">Overview</h3>
        <img src={`${import.meta.env.BASE_URL}architecture-overview-en.png`} alt="OpsView Architecture Overview"
             class="arch-zoomable cursor-zoom-in w-full h-auto transition-transform duration-300 hover:scale-[1.02]" loading="lazy">
      </div>
      <div class="rounded-xl border border-white/5 overflow-hidden bg-dark-800 p-2">
        <h3 class="w-full text-left font-mono text-xs uppercase text-slate-400 tracking-widest mb-2 border-b border-white/10 pb-2 px-2 pt-2">Detail</h3>
        <img src={`${import.meta.env.BASE_URL}architecture-detail.png`} alt="OpsView Architecture Detail"
             class="arch-zoomable cursor-zoom-in w-full h-auto transition-transform duration-300 hover:scale-[1.02]" loading="lazy">
      </div>
    </div>
  </div>
</section>
