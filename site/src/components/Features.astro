---
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const features = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zm0 8a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1v-2zm0 8a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1v-2z"/>`,
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9"/>`,
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>`,
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>`,
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>`,
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
  },
];
---

<section id="features" class="py-20 px-6 relative z-10 bg-gradient-to-b from-transparent via-[#020617] to-transparent">
  <div class="max-w-7xl mx-auto">
    <div class="flex items-center gap-4 mb-16">
      <div class="h-px bg-[#22d3ee]/30 flex-1"></div>
      <h2 class="font-mono text-2xl font-bold text-[#22d3ee] tracking-[0.2em] uppercase text-glow">{t('features.title')}</h2>
      <div class="h-px bg-[#22d3ee]/30 flex-1"></div>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map((f, i) => {
        // Cycle through cyan, magenta, blue
        const colors = [
          { text: 'text-[#22d3ee]', bg: 'bg-[#22d3ee]/10', border: 'border-[#22d3ee]/30', shadow: 'shadow-[0_0_15px_rgba(34,211,238,0.2)]', hoverBg: 'group-hover:bg-[#22d3ee]/20' },
          { text: 'text-[#ec4899]', bg: 'bg-[#ec4899]/10', border: 'border-[#ec4899]/50', shadow: 'shadow-[0_0_15px_rgba(236,72,153,0.3)]', hoverBg: 'group-hover:bg-[#ec4899]/20' },
          { text: 'text-[#3b82f6]', bg: 'bg-[#3b82f6]/10', border: 'border-[#3b82f6]/50', shadow: 'shadow-[0_0_15px_rgba(59,130,246,0.3)]', hoverBg: 'group-hover:bg-[#3b82f6]/20' }
        ];
        const c = colors[i % 3];
        const keyBase = `feature.${i + 1}`;
        // @ts-ignore dynamic key mapping
        const titleText = t(`${keyBase}.title` as any);
        // @ts-ignore dynamic key mapping
        const descText = t(`${keyBase}.desc` as any);
        
        return (
          <div class={`glass-panel p-8 group hover:-translate-y-2 transition-transform duration-300 border ${c.shadow.replace('15px', '20px')}`}>
            <div class={`w-12 h-12 rounded-lg flex items-center justify-center mb-6 border ${c.bg} ${c.border} ${c.hoverBg} transition-colors ${c.shadow}`}>
              <svg class={`w-6 h-6 ${c.text}`} fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <Fragment set:html={f.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-3 font-mono">{titleText}</h3>
            <p class="text-slate-400 leading-relaxed text-sm">{descText}</p>
          </div>
        )
      })}
    </div>
  </div>
</section>
