---

<section id="features" class="py-20 px-6">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold text-white text-center mb-4">핵심 기능</h2>
    <p class="text-gray-400 text-center mb-14 max-w-xl mx-auto">고성능 원격 데스크톱을 위한 모든 것</p>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((f) => (
        <div class="p-6 rounded-xl bg-dark-800 border border-white/5 hover:border-brand-500/30 transition">
          <div class="w-10 h-10 rounded-lg bg-brand-600/15 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <Fragment set:html={f.icon} />
            </svg>
          </div>
          <h3 class="text-white font-semibold mb-2">{f.title}</h3>
          <p class="text-sm text-gray-400">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
