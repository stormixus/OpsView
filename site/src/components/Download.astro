---
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const downloads = [
  {
    name: 'Agent',
    platform: 'Windows',
    colorClass: 'bg-blue-500/10',
    iconColorClass: 'text-blue-400',
    icon: `<path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/>`,
  },
  {
    name: 'Viewer',
    platform: 'Windows',
    colorClass: 'bg-blue-500/10',
    iconColorClass: 'text-blue-400',
    icon: `<path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/>`,
  },
  {
    name: 'Viewer',
    platform: 'macOS',
    colorClass: 'bg-gray-500/10',
    iconColorClass: 'text-gray-400',
    icon: `<path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>`,
  },
  {
    name: 'Viewer',
    platform: 'Linux',
    colorClass: 'bg-orange-500/10',
    iconColorClass: 'text-orange-400',
    icon: `<path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a.424.424 0 00-.11.135c-.26.268-.45.6-.663.839-.199.199-.485.267-.797.4-.313.136-.658.269-.864.68-.09.189-.136.394-.132.602 0 .199.027.4.055.536.058.399.116.728.04.97-.249.68-.28 1.145-.106 1.484.174.334.535.47.94.601.81.2 1.91.135 2.774.6.926.466 1.866.67 2.616.47.526-.116.97-.464 1.208-.946.587-.003 1.23-.269 2.26-.334.699-.058 1.574.267 2.577.2.025.134.063.198.114.333l.003.003c.391.778 1.113 1.368 1.884 1.43.868.065 1.544-.468 2.192-1.002l.005-.004c.329-.272.586-.6.881-.817.38-.281.813-.4 1.285-.4.413.064.59.164.987.266.376.1.812.164 1.383-.068.202-.078.41-.185.563-.334.326-.299.5-.647.506-1.033.007-.167-.026-.384-.107-.553a.988.988 0 00-.345-.391c-.204-.147-.523-.238-.978-.267-.543-.03-.993.062-1.418.166-.215.047-.4.074-.564.074h-.007c-.206 0-.385-.04-.536-.115-.15-.073-.298-.185-.42-.32-.122-.131-.198-.253-.253-.375-.058-.1-.199-.28-.199-.396a.54.54 0 01.2-.397c.406-.37.44-1.132-.044-1.556-.233-.21-.583-.305-.806-.405l-.003-.001a.902.902 0 01-.397-.291c-.146-.178-.182-.398-.182-.597 0-.028.002-.06.005-.082v-.003c.152-.331.383-.667.503-.999.12-.334.122-.665-.052-1.024-.238-.5-.536-.665-.807-.87-.393-.3-.744-.503-1.05-.934-.358-.537-.567-1.232-.567-2.148 0-2.068-1.178-3.42-2.38-4.233C14.404.632 12.952 0 12.504 0z"/>`,
