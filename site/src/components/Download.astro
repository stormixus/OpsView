---

<section id="download" class="py-20 px-6 relative z-10">
  <div class="max-w-7xl mx-auto">
    <div class="flex items-center gap-4 mb-16">
      <div class="h-px bg-[#3b82f6]/30 flex-1"></div>
      <h2 class="font-mono text-2xl font-bold text-[#3b82f6] tracking-[0.2em] uppercase drop-shadow-[0_0_10px_rgba(59,130,246,0.4)]">{t('nav.download')}</h2>
      <div class="h-px bg-[#3b82f6]/30 flex-1"></div>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {downloads.map((d) => (
        <a href="https://github.com/stormixus/OpsView/releases/latest"
           class="glass-panel p-6 group hover:-translate-y-1 transition-transform duration-300 border border-[#3b82f6]/20 shadow-[0_0_15px_rgba(59,130,246,0.15)] text-center block">
          <div class={`w-12 h-12 rounded-lg bg-[#020617] flex items-center justify-center mx-auto mb-4 border border-white/5 shadow-[inset_0_0_15px_Math.rgba(0,0,0,0.5)]`}>
            <svg class={`w-6 h-6 ${d.iconColorClass}`} fill="currentColor" viewBox="0 0 24 24">
              <Fragment set:html={d.icon} />
            </svg>
          </div>
          <h3 class="text-white font-mono tracking-widest font-semibold mb-1 uppercase">{d.name}</h3>
          <p class="text-xs text-slate-500 font-mono tracking-wider">{d.platform}</p>
          <span class="inline-block mt-4 text-xs font-mono tracking-widest text-[#3b82f6] group-hover:text-white transition-colors uppercase">{t('download.cta')} &rarr;</span>
        </a>
      ))}
    </div>
  </div>
</section>
