---
import { getLangFromUrl, useTranslations, languages } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<header class="fixed top-0 w-full z-50 border-b border-[#22d3ee]/20 bg-[rgba(15,23,42,0.7)] backdrop-blur-md">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    <a href={`${import.meta.env.BASE_URL}${lang}/`} class="flex items-center gap-3">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8 text-[#22d3ee] drop-shadow-[0_0_8px_rgba(34,211,238,0.8)]"><path d="M2 12h4l3-9 5 18 3-9h5"/></svg>
      <span class="font-mono font-bold text-2xl tracking-widest text-white text-glow">OPSVIEW</span>
    </a>
    
    <nav class="hidden md:flex items-center gap-8 font-mono text-sm tracking-widest uppercase">
      <a href={`${import.meta.env.BASE_URL}${lang}/`} class="text-[#22d3ee] hover:text-white transition-colors text-glow relative before:content-[''] before:absolute before:-bottom-2 before:left-0 before:w-0 before:h-0.5 before:bg-[#22d3ee] before:transition-all hover:before:w-full">{t('nav.home')}</a>
      <a href="#features" class="text-slate-400 hover:text-[#22d3ee] transition-colors">{t('nav.features')}</a>
      <a href="#architecture" class="text-slate-400 hover:text-[#22d3ee] transition-colors">{t('nav.about')}</a>
      <a href="#download" class="text-slate-400 hover:text-[#22d3ee] transition-colors">{t('nav.download')}</a>
      <a href="https://github.com/stormixus/OpsView" target="_blank" class="text-slate-400 hover:text-[#22d3ee] transition-colors">{t('nav.github')}</a>
    </nav>

    <div class="relative" id="lang-switcher">
      <button id="lang-btn" class="flex items-center gap-2 font-mono text-xs tracking-widest uppercase text-slate-400 hover:text-[#22d3ee] transition-colors border border-white/10 hover:border-[#22d3ee]/30 rounded px-3 py-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9"/></svg>
        {languages[lang]}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div id="lang-menu" class="hidden absolute right-0 top-full mt-2 min-w-[140px] border border-[#22d3ee]/20 bg-[rgba(15,23,42,0.95)] backdrop-blur-md rounded-lg overflow-hidden shadow-[0_0_20px_rgba(34,211,238,0.15)]">
        {Object.entries(languages).map(([code, label]) => (
          <a href={`${import.meta.env.BASE_URL}${code}/`}
             class={`block px-4 py-2.5 font-mono text-xs tracking-wider transition-colors ${code === lang ? 'text-[#22d3ee] bg-[#22d3ee]/10' : 'text-slate-400 hover:text-white hover:bg-white/5'}`}>
            {label}
          </a>
        ))}
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('lang-btn');
  const menu = document.getElementById('lang-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  document.addEventListener('click', (e) => {
    if (!(e.target as Element)?.closest('#lang-switcher')) {
      menu?.classList.add('hidden');
    }
  });
</script>
