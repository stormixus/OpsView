---
import Layout from '../layouts/Layout.astro';
import LanguagePicker from './LanguagePicker.astro';
import { useTranslations } from '../i18n/ui';
import type { defaultLang } from '../i18n/ui';

interface Props {
  lang: keyof typeof import('../i18n/ui').ui;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<Layout title={`OpsView | ${t('nav.home')}`} lang={lang}>
  <!-- Top Navigation -->
  <header class="w-full relative z-20 border-b border-cyber-cyan/20 bg-cyber-dark-glass backdrop-blur-md">
    <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8 text-cyber-cyan drop-shadow-[0_0_8px_rgba(34,211,238,0.8)]"><path d="M2 12h4l3-9 5 18 3-9h5"/></svg>
        <span class="font-mono font-bold text-2xl tracking-widest text-white text-glow">OPSVIEW</span>
      </div>
      
      <nav class="hidden md:flex items-center gap-8 font-mono text-sm tracking-widest uppercase">
        <a href="#" class="text-cyber-cyan hover:text-white transition-colors text-glow relative before:content-[''] before:absolute before:-bottom-2 before:left-0 before:w-0 before:h-0.5 before:bg-cyber-cyan before:transition-all hover:before:w-full">{t('nav.home')}</a>
        <a href="#features" class="text-slate-400 hover:text-cyber-cyan transition-colors">{t('nav.about')}</a>
        <a href="https://github.com/stormixus/OpsView" target="_blank" class="text-slate-400 hover:text-cyber-cyan transition-colors">{t('nav.github')}</a>
      </nav>

      <LanguagePicker />
    </div>
  </header>

  <!-- Hero Section -->
  <main class="w-full flex-1 flex flex-col items-center justify-center relative z-10 px-6 py-20 min-h-[80vh]">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(34,211,238,0.08)_0%,transparent_60%)] pointer-events-none"></div>
    
    <div class="text-center max-w-4xl mx-auto flex flex-col items-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-cyber-magenta/10 border border-cyber-magenta/30 rounded-full text-cyber-magenta font-mono text-xs uppercase tracking-widest mb-8 shadow-[0_0_15px_rgba(236,72,153,0.3)]">
        <span class="w-2 h-2 rounded-full bg-cyber-magenta animate-pulse"></span>
        System Online
      </div>
      
      <h1 class="text-5xl md:text-7xl font-bold font-mono tracking-tighter mb-6 leading-tight">
        <span class="glitch-wrapper block mb-2">
          <span class="glitch uppercase" data-text={t('hero.title')}>{t('hero.title')}</span>
        </span>
      </h1>
      
      <p class="text-lg md:text-xl text-slate-400 max-w-2xl mb-12 leading-relaxed">
        {t('hero.subtitle')}
      </p>

      <div class="flex flex-col sm:flex-row items-center gap-6">
        <a href="#architecture" class="btn-cyber block text-center">
          {t('hero.cta')}
        </a>
        <a href="https://github.com/stormixus/OpsView" target="_blank" class="flex items-center gap-2 font-mono text-slate-300 hover:text-cyber-cyan transition-colors uppercase tracking-widest border-b border-transparent hover:border-cyber-cyan pb-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          {t('nav.github')}
        </a>
      </div>
    </div>
  </main>

  <!-- Architecture Section -->
  <section id="architecture" class="w-full relative z-10 px-6 py-24 bg-[#020617]/80 backdrop-blur-sm border-y border-cyber-cyan/10">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center gap-4 mb-16">
        <div class="h-px bg-cyber-magenta/30 flex-1"></div>
        <h2 class="font-mono text-2xl font-bold text-cyber-magenta tracking-[0.2em] uppercase text-magenta-glow">{t('arch.title')}</h2>
        <div class="h-px bg-cyber-magenta/30 flex-1"></div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div class="glass-panel p-2 flex flex-col group border-cyber-magenta/20 overflow-hidden">
          <div class="bg-[#050a12] rounded-lg p-6 flex-1 flex flex-col items-center justify-center relative">
            <h3 class="w-full text-left font-mono text-xs uppercase text-slate-400 tracking-widest mb-4 border-b border-white/10 pb-2">{t('arch.overview')}</h3>
            <img src={`${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/${lang === 'ko' ? 'architecture-overview.png' : 'architecture-overview-en.png'}`} alt="Architecture Overview" class="w-full h-auto object-contain rounded drop-shadow-[0_0_15px_rgba(236,72,153,0.1)] group-hover:scale-[1.02] transition-transform duration-500 ease-out" />
          </div>
        </div>

        <div class="glass-panel p-2 flex flex-col group border-cyber-cyan/20 overflow-hidden">
          <div class="bg-[#050a12] rounded-lg p-6 flex-1 flex flex-col items-center justify-center relative">
             <h3 class="w-full text-left font-mono text-xs uppercase text-slate-400 tracking-widest mb-4 border-b border-white/10 pb-2">{t('arch.detail')}</h3>
            <img src={`${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/architecture-detail.png`} alt="Architecture Detail" class="w-full h-auto object-contain rounded drop-shadow-[0_0_15px_rgba(34,211,238,0.1)] group-hover:scale-[1.02] transition-transform duration-500 ease-out" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Overlay Grid -->
  <section id="features" class="w-full relative z-10 px-6 py-24 bg-gradient-to-b from-transparent via-[#020617] to-[#050c16]">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center gap-4 mb-16">
        <div class="h-px bg-cyber-cyan/30 flex-1"></div>
        <h2 class="font-mono text-2xl font-bold text-cyber-cyan tracking-[0.2em] uppercase text-glow">{t('features.title')}</h2>
        <div class="h-px bg-cyber-cyan/30 flex-1"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Card 1 -->
        <div class="glass-panel p-8 group hover:-translate-y-2 transition-transform duration-300">
          <div class="w-12 h-12 bg-cyber-cyan/10 rounded-lg flex items-center justify-center mb-6 border border-cyber-cyan/30 group-hover:bg-cyber-cyan/20 transition-colors shadow-[0_0_15px_rgba(34,211,238,0.2)]">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyber-cyan"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="7.5 4.21 12 6.81 16.5 4.21"/><polyline points="7.5 19.79 7.5 14.6 3 12"/><polyline points="21 12 16.5 14.6 16.5 19.79"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3 font-mono">{t('feature.1.title')}</h3>
          <p class="text-slate-400 leading-relaxed text-sm">
            {t('feature.1.desc')}
          </p>
        </div>

        <!-- Card 2 -->
        <div class="glass-panel p-8 group hover:-translate-y-2 transition-transform duration-300 !shadow-[0_0_20px_rgba(236,72,153,0.3)] !border-cyber-magenta/30">
          <div class="w-12 h-12 bg-cyber-magenta/10 rounded-lg flex items-center justify-center mb-6 border border-cyber-magenta/50 group-hover:bg-cyber-magenta/20 transition-colors shadow-[0_0_15px_rgba(236,72,153,0.4)]">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyber-magenta"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3 font-mono">{t('feature.2.title')}</h3>
          <p class="text-slate-400 leading-relaxed text-sm">
            {t('feature.2.desc')}
          </p>
        </div>

        <!-- Card 3 -->
        <div class="glass-panel p-8 group hover:-translate-y-2 transition-transform duration-300">
          <div class="w-12 h-12 bg-cyber-blue/10 rounded-lg flex items-center justify-center mb-6 border border-cyber-blue/50 group-hover:bg-cyber-blue/20 transition-colors shadow-[0_0_15px_rgba(59,130,246,0.3)]">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyber-blue"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3 font-mono">{t('feature.3.title')}</h3>
          <p class="text-slate-400 leading-relaxed text-sm">
            {t('feature.3.desc')}
          </p>
        </div>

        <!-- Card 4 -->
        <div class="glass-panel p-8 group hover:-translate-y-2 transition-transform duration-300">
          <div class="w-12 h-12 bg-cyber-cyan/10 rounded-lg flex items-center justify-center mb-6 border border-cyber-cyan/30 group-hover:bg-cyber-cyan/20 transition-colors shadow-[0_0_15px_rgba(34,211,238,0.2)]">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyber-cyan"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3 font-mono">{t('feature.4.title')}</h3>
          <p class="text-slate-400 leading-relaxed text-sm">
            {t('feature.4.desc')}
          </p>
        </div>

        <!-- Card 5 -->
        <div class="glass-panel p-8 group hover:-translate-y-2 transition-transform duration-300">
          <div class="w-12 h-12 bg-cyber-magenta/10 rounded-lg flex items-center justify-center mb-6 border border-cyber-magenta/50 group-hover:bg-cyber-magenta/20 transition-colors shadow-[0_0_15px_rgba(236,72,153,0.3)]">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyber-magenta"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3 font-mono">{t('feature.5.title')}</h3>
          <p class="text-slate-400 leading-relaxed text-sm">
            {t('feature.5.desc')}
          </p>
        </div>

        <!-- Card 6 -->
        <div class="glass-panel p-8 group hover:-translate-y-2 transition-transform duration-300">
          <div class="w-12 h-12 bg-cyber-blue/10 rounded-lg flex items-center justify-center mb-6 border border-cyber-blue/50 group-hover:bg-cyber-blue/20 transition-colors shadow-[0_0_15px_rgba(59,130,246,0.3)]">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyber-blue"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3 font-mono">{t('feature.6.title')}</h3>
          <p class="text-slate-400 leading-relaxed text-sm">
            {t('feature.6.desc')}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Minimal Footer -->
  <footer class="w-full relative z-10 border-t border-cyber-cyan/10 bg-[#020617] mt-auto">
    <div class="max-w-7xl mx-auto px-6 py-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-cyber-cyan shadow-[0_0_8px_rgba(34,211,238,0.8)]"></span>
        <p class="font-mono text-xs text-slate-500 tracking-widest uppercase">{t('footer.text')}</p>
      </div>
      <p class="font-mono text-xs text-slate-600">v1.0.0. [SYS_READY]</p>
    </div>
  </footer>
</Layout>
