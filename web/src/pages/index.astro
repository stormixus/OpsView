---
import Landing from '../components/Landing.astro';
import { defaultLang } from '../i18n/ui';

// Astro handles generating the root `/` page when base is defined.
// This simply renders the default language on the root path.
// Or we could redirect to `/en/`, but rendering raw is also fine,
// except we want the LanguagePicker to reflect the path. 
// Using `window.location.replace` or meta tag for a true redirect so `LangPicker` logic holds.
---

<!doctype html>
<html lang={defaultLang}>
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={`0;url=./${defaultLang}/`} />
    <title>Redirecting...</title>
  </head>
  <body class="bg-[#050c16]">
    <!-- Redirecting to default language -->
  </body>
</html>
