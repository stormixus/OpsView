# === Relay ===
RELAY_PORT=8080
RELAY_PUBLISHER_TOKEN=change-me-publisher-secret
RELAY_WATCHER_TOKENS=watcher-token-1,watcher-token-2
RELAY_WEB_DIR=../web

# === Agent ===
AGENT_RELAY_URL=ws://127.0.0.1:8080/publish
AGENT_TOKEN=change-me-publisher-secret
AGENT_PROFILE=1080
AGENT_FPS_MIN=5
AGENT_FPS_MAX=10
AGENT_TILE_SIZE=128

# === Viewer / Web ===
WATCH_URL=ws://127.0.0.1:8080/watch
WATCH_TOKEN=watcher-token-1
